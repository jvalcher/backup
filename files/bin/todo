#!/bin/bash
#
# Output all source code tags recursively starting in cwd
#

C_CYAN_BOLD="\x1b[1;36m"
C_YELLOW="\x1b[0;33m"
C_GREEN_DIM="\x1b[2;32m"
C_BLUE="\x1b[0;34m"
C_MAGENTA="\x1b[0;35m"
C_CYAN="\x1b[0;36m"
C_RED="\x1b[0;31m"
C_RESET="\x1b[0m"

grep -rn --include=* \
    --exclude-dir=node_modules \
    --exclude-dir=.git \
    --exclude='package*' \
    -e "NOTE: " \
    -e "OPTIMIZE: " \
    -e "TODO: " \
    -e "HACK: " \
    -e "XXX: " \
    -e "FIXME: " \
    -e "BUG: " . 2>/dev/null --color=auto \
| sed \
    -e "s/^.[^:]*/${C_CYAN_BOLD}&${C_RESET}/g" \
    -e "s/NOTE/${C_YELLOW}&${C_RESET}/g" \
    -e "s/OPTIMIZE/${C_YELLOW}&${C_RESET}/g" \
    -e "s/TODO/${C_YELLOW}&${C_RESET}/g" \
    -e "s/HACK/${C_YELLOW}&${C_RESET}/g" \
    -e "s/XXX/${C_MAGENTA}&${C_RESET}/g" \
    -e "s/FIXME/${C_RED}&${C_RESET}/g" \
    -e "s/BUG/${C_RED}&${C_RESET}/g"
