#!/usr/bin/python3

import sys

def parse_time(t):
    try:
        minutes, seconds = map(int, t.strip().split(':'))
        return minutes * 60 + seconds
    except:
        print(f"Invalid format: {t}. Use mm:ss.")
        return None

def format_time(total_seconds):
    minutes = total_seconds // 60
    seconds = total_seconds % 60
    return f"{minutes}:{seconds:02d}"

def main():
    print("Enter times in mm:ss format. Press Ctrl+C to stop.")
    total = 0
    while True:
        try:
            user_input = input("Time: ")
            sec = parse_time(user_input)
            if sec is not None:
                total += sec
                print("Running Total:", format_time(total))
        except KeyboardInterrupt:
            print("\nStopped.")
            break

if __name__ == "__main__":
    main()
