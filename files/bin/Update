#!/bin/bash

G="\033[0;32m"
E="\033[0m"

printf "\n----${G}apt${E}----\n"
printf "\n    --update--\n\n"
sudo apt update
printf "\n    --upgrade--\n\n"
sudo apt upgrade -y
printf "\n    --autoremove--\n\n"
sudo apt autoremove -y

printf "\n"
printf "\n---${G}snap${E}----\n"
printf "\n    --refresh--\n\n"
sudo snap refresh

printf "\n"
printf "\n---${G}brew${E}----\n"
printf "\n    --update--\n\n"
brew update
printf "\n    --upgrade--\n\n"
brew upgrade -y

printf "\n"
printf "\n---${G}rust${E}----\n"
printf "\n    --update--\n\n"
rustup update -y

printf "\n\n"
