#!/bin/bash
#
# Print all man 3 functions with containing man page's brief description
#

MAN="3"
DOC="$HOME/Documents/dev/functions_man${MAN}.txt"

man -k . \
  | grep "(${MAN})" \
  | awk -F ' - ' '{ print $2 "::: " $0 }' \
  | sort \
  | sed 's/^[^:]*:::[ ]*//' \
  > "$DOC"

nvim "$DOC"
rm "$DOC"
